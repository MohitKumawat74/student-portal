<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Portal | Homepage</title>
    <link rel="stylesheet" href="/styles.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://kit.fontawesome.com/your-fontawesome-kit.js" crossorigin="anonymous"></script>
</head>
<body>

    <%- include('partials/navbar3') %>

<div class="container mt-4">
  <!-- Hero Section -->
  <div class="hero-section text-center">
    <h1 class="fade-in">Welcome to the Student Portal</h1>
    <p class="fade-in delay-1">Manage your courses, track your progress, and explore new learning opportunities.</p>
  </div>

  <!-- Features Section -->
  <div class="row mt-4">
    <div class="col-md-4">
      <div class="card feature-card text-center p-4">
        <i class="fas fa-book fa-3x text-primary mb-3"></i>
        <h5>Courses</h5>
        <p>Explore a variety of courses and enroll in the best ones.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card feature-card text-center p-4">
        <i class="fas fa-user fa-3x text-success mb-3"></i>
        <h5>Student Profile</h5>
        <p>View and update your personal and academic details.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card feature-card text-center p-4">
        <i class="fas fa-chart-line fa-3x text-warning mb-3"></i>
        <h5>Performance</h5>
        <p>Track your grades and achievements in one place.</p>
      </div>
    </div>
  </div>
</div>

<footer class="footer">
  <div class="footer-container text-center">
    <p>&copy; <%= new Date().getFullYear() %> Student Portal | All Rights Reserved</p>
  </div>
</footer>


<script>
  // GSAP Animations
  gsap.from(".fade-in", { opacity: 0, y: 30, duration: 1, stagger: 0.2 });

  // Hover effect on feature cards
  $(".feature-card").hover(
    function () { gsap.to(this, { scale: 1.05, duration: 0.3 }); },
    function () { gsap.to(this, { scale: 1, duration: 0.3 }); }
  );
</script>

</body>
</html>
