<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="/styles.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
</head>
<body>
    <%- include('partials/navbar4') %>
    
    <div class="container-fluid" id="Dashboard">
        <div class="row justify-content-md-center">
            <div class="col-md-10">
                <h1 class="text-center mt-4 mb-4 dash">Dashboard</h1>

                <!-- Admin Logout Button -->
                <div class="text-center mb-3">
                    <a href="/admin/logout" class="btn btn-danger">Logout</a>
                </div>

                <table class="table table-dark table-striped text-center">
                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th>Student Name</th>
                            <th>Age</th>
                            <th>Email</th>
                            <th>Fees</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (records && records.length > 0) { %>
                            <% records.forEach((item, index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td> <!-- Serial Number -->
                                    <td><%= item.StuName %></td>
                                    <td><%= item.StuAge %></td>
                                    <td><%= item.StuEmail %></td>
                                    <td>$<%= item.StuFess %></td>
                                    <td>
                                        <!-- Edit Button (Triggers Modal) -->
                                        <button class="btn btn-warning btn-sm edit-btn" 
                                            data-id="<%= item._id %>" 
                                            data-name="<%= item.StuName %>"
                                            data-age="<%= item.StuAge %>"
                                            data-email="<%= item.StuEmail %>"
                                            data-fees="<%= item.StuFess %>">
                                            Edit
                                        </button>

                                        <!-- Delete Button -->
                                        <a href="#" class="btn btn-danger btn-sm delete-btn" data-id="<%= item._id %>">
                                            Delete
                                        </a>
                                        
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center">No student records available.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Edit Student Modal -->
    <div class="modal fade" id="editModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Student</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form action="/update" method="POST">
                        <input type="hidden" id="editId" name="id"> <!-- Ensure _id is passed -->
                        <div class="mb-3">
                            <label>Name:</label>
                            <input type="text" class="form-control" id="editName" name="name" required>
                        </div>
                        <div class="mb-3">
                            <label>Age:</label>
                            <input type="number" class="form-control" id="editAge" name="age" required>
                        </div>
                        <div class="mb-3">
                            <label>Email:</label>
                            <input type="email" class="form-control" id="editEmail" name="email" required>
                        </div>
                        <div class="mb-3">
                            <label>Fees:</label>
                            <input type="number" class="form-control" id="editFees" name="fees" required>
                        </div>
                        <button type="submit" class="btn btn-primary">Update</button>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>

    <script>
        // Handle Edit Button Click
        $(document).ready(function(){
    $(".edit-btn").click(function(){
        let id = $(this).data("id");
        let name = $(this).data("name");
        let age = $(this).data("age");
        let email = $(this).data("email");
        let fees = $(this).data("fees");

        $("#editId").val(id);
        $("#editName").val(name);
        $("#editAge").val(age);
        $("#editEmail").val(email);
        $("#editFees").val(fees);

        $("#editModal").modal("show");
    });
});

    </script>

    <script>
        // Handle Delete Button Click
        $(document).ready(function () {
    $(".delete-btn").click(function (e) {
        e.preventDefault(); // Prevent default behavior

        let studentId = $(this).data("id");

        if (confirm("Are you sure you want to delete this student?")) {
            $.ajax({
                url: "/delete/" + studentId, // Fix the URL
                type: "DELETE", // Change request method
                success: function (response) {
                    alert(response.message);
                    location.reload(); // Refresh page after delete
                },
                error: function (xhr) {
                    alert("Error deleting student: " + xhr.responseText);
                }
            });
        }
    });
});

    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
