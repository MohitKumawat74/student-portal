<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us | Student Portal</title>
    <link rel="stylesheet" href="/styles.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/your-fontawesome-kit.js" crossorigin="anonymous"></script>
</head>
<body>
    <%- include('partials/navbar3') %>

<div class="container mt-4">
  <!-- Hero Section -->
  <div class="hero-section text-center">
    <h1 class="fade-in">About Our Student Portal</h1>
    <p class="fade-in delay-1">Empowering students with seamless access to courses, progress tracking, and academic resources.</p>
  </div>

  <!-- About Content -->
  <div class="row mt-4 align-items-center">
    <div class="col-md-6 aboutimg">
    </div>
    <div class="col-md-5 ms-5">
      <h2 class="fade-in">Who We Are</h2>
      <p class="paragraph fade-in">
        Our Student Portal is designed to enhance the learning experience by providing an easy-to-use platform
        for students to enroll in courses, track their progress, and manage their academic profiles efficiently.
      </p>
      <h3 class="our fade-in">Our Mission</h3>
      <p class="paragraph fade-in">
        We aim to make education accessible and engaging through digital innovations, helping students stay organized
        and motivated.
      </p>
    </div>
  </div>

  <!-- Features Section -->
  <div class="row mt-5">
    <div class="col-md-4">
      <div class="card text-center p-4 feature-card">
        <i class="fas fa-graduation-cap fa-3x text-primary mb-3"></i>
        <h5>Quality Education</h5>
        <p>Access top-tier courses from the best educators.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center p-4 feature-card">
        <i class="fas fa-laptop-code fa-3x text-success mb-3"></i>
        <h5>Smart Learning</h5>
        <p>Interactive and engaging digital content for effective learning.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center p-4 feature-card">
        <i class="fas fa-users fa-3x text-warning mb-3"></i>
        <h5>Community Support</h5>
        <p>Connect with peers and mentors to excel in your studies.</p>
      </div>
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="footer">
  <div class="footer-container text-center">
    <p>&copy; <%= new Date().getFullYear() %> Student Portal | All Rights Reserved</p>
  </div>
</footer>

<script>
  // Add Scroll Animation on Hero Section
  document.addEventListener("DOMContentLoaded", function () {
      const elements = document.querySelectorAll(".fade-in");
      elements.forEach(el => {
          el.style.opacity = 0;
          el.style.transform = "translateY(20px)";
      });

      function fadeInOnScroll() {
          elements.forEach(el => {
              const position = el.getBoundingClientRect().top;
              const screenHeight = window.innerHeight;
              if (position < screenHeight - 100) {
                  el.style.transition = "all 0.8s ease-in-out";
                  el.style.opacity = 1;
                  el.style.transform = "translateY(0)";
              }
          });
      }

      window.addEventListener("scroll", fadeInOnScroll);
      fadeInOnScroll();
  });
</script>

</body>
</html>
