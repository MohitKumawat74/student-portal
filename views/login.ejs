<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/styles.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body class="login-body">
    <%- include('partials/navbar2') %>
    
    <div class="login-container">
        <h2 class="login-title">Welcome Back</h2>
        <form action="/login" method="POST" class="login-form">
            <div class="input-group">
                <label for="email">Email:</label>
                <input type="email" name="email" id="email" required>
            </div>
            <div class="input-group">
                <label for="password">Password:</label>
                <input type="password" name="password" id="password" required>
            </div>
            <a href="/profile"><button type="submit" class="btn btn-primary login-btn">Login</button></a>
        </form>
        <p class="register-text">Don't have an account? <a href="/register">Register here</a></p>
    </div>

    <script>
        // GSAP Animation
        gsap.from(".login-container", { duration: 1.5, opacity: 0, y: -50, ease: "bounce" });
        gsap.from(".login-title", { duration: 1, opacity: 0, y: -30, delay: 0.5 });
        gsap.from(".input-group", { duration: 1, opacity: 0, stagger: 0.3, delay: 0.8 });
        gsap.from(".login-btn", { duration: 1, opacity: 0, scale: 0.8, delay: 1 });
    </script>
</body>
</html>
